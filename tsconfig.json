{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "types": ["jest", "node"],
    "strictNullChecks": false,
    "noImplicitAny": false,
    "paths": { "@/*": ["src/*"] }
  },
  "include": ["src/**/*", "mock-hcm/**/*", "test/**/*"],
  "exclude": ["node_modules", "dist"]
}
